# Server env (example — copy to .env and fill in)
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB — leave blank in dev to auto-start an in-memory MongoDB.
# In production, set to your real MongoDB connection string.
MONGODB_URI=

# Auth
JWT_SECRET=replace-with-a-strong-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@12345

# Payments (MOCK mode if no real keys)
PAYMENT_PROVIDER=MOCK
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=

# Email (MOCK mode if no server)
EMAIL_SERVER=
EMAIL_FROM=no-reply@lumiere.store

# App
APP_URL=http://localhost:3000
